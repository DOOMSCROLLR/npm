{
  "name": "@doomscrollr/api",
  "version": "0.1.2",
  "description": "Official typed JavaScript/TypeScript SDK for the DOOMSCROLLR REST API.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "examples/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test test/*.test.mjs",
    "pack:dry": "npm pack --dry-run",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "doomscrollr",
    "ai",
    "doomscrollr-api",
    "api-client",
    "sdk",
    "typescript",
    "javascript",
    "rest-api",
    "owned-audience",
    "creator-tools",
    "creator-economy",
    "newsletter",
    "commerce",
    "subscribers",
    "link-in-bio",
    "linktree",
    "shopify",
    "mcp"
  ],
  "author": "DOOMSCROLLR",
  "license": "MIT",
  "homepage": "https://doomscrollr.com/api",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DOOMSCROLLR/npm.git"
  },
  "bugs": {
    "url": "https://github.com/DOOMSCROLLR/npm/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
